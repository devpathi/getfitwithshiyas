---
import "../styles/global.css";
import "@fontsource/sora/600.css";
import "@fontsource/sora/700.css";
import "@fontsource-variable/inter";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import WhatsAppButton from "../components/WhatsAppButton.astro";
import site from "../data/site.json";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = `${site.name} | Personal Trainer in Bengaluru`,
  description = `${site.tagline}. In-person & online personal training and coaching with ${site.trainer} — ${site.yearsExperience} years of experience.`,
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site).href;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content="/images/og-image.jpg" />
    <meta name="twitter:card" content="summary_large_image" />

    <!-- Netlify Identity: lets /admin invite links log in and redirect to the editor -->
    <script is:inline src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>
    <script is:inline>
      if (window.netlifyIdentity) {
        window.netlifyIdentity.on("init", (user) => {
          if (!user) {
            window.netlifyIdentity.on("login", () => {
              document.location.href = "/admin/";
            });
          }
        });
      }
    </script>
  </head>
  <body class="flex min-h-screen flex-col bg-white text-ink antialiased">
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
    <WhatsAppButton />
  </body>
</html>
