---
interface Props {
  title: string;
  summary: string;
  mode: string;
  bestFor?: string;
}
const { title, summary, mode, bestFor } = Astro.props;
---

<article class="group flex h-full flex-col rounded-2xl border border-black/8 bg-white p-7 transition hover:border-accent hover:shadow-lg hover:shadow-black/5">
  <span class="inline-flex w-fit rounded-full bg-cream px-3 py-1 text-xs font-semibold text-accent-dark">{mode}</span>
  <h3 class="mt-4 text-xl font-bold">{title}</h3>
  <p class="mt-3 flex-1 text-sm leading-relaxed text-ink/70">{summary}</p>
  {bestFor && <p class="mt-4 text-xs text-muted"><strong class="text-ink/60">Best for:</strong> {bestFor}</p>}
  <a href="/book" class="mt-5 inline-flex items-center gap-1.5 text-sm font-semibold text-accent-dark group-hover:gap-2.5 transition-all">
    Start this program →
  </a>
</article>
