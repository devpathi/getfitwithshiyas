---
import site from "../data/site.json";
const year = new Date().getFullYear();
const waLink = `https://wa.me/${site.whatsapp}?text=${encodeURIComponent(site.whatsappMessage)}`;
---

<footer class="bg-ink text-white/80">
  <div class="container-tight grid gap-10 py-14 md:grid-cols-4">
    <div class="md:col-span-2">
      <div class="flex items-center">
        <img src="/images/logo.jpeg" alt={site.name} class="h-10 w-auto object-contain brightness-0 invert" />
      </div>
      <p class="mt-4 max-w-sm text-sm leading-relaxed text-white/60">
        {site.tagline}. Personalised in-person & online coaching with {site.trainer},
        {site.yearsExperience} years of experience, based in {site.city}.
      </p>
      <!-- Social icons -->
      <div class="mt-5 flex gap-4">
        <a href={site.social.instagram} aria-label="Instagram" target="_blank" rel="noopener noreferrer" class="footer-social">
          <!-- Instagram -->
          <svg viewBox="0 0 24 24" fill="currentColor" width="18" height="18"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
        </a>
        <a href={site.social.facebook} aria-label="Facebook" target="_blank" rel="noopener noreferrer" class="footer-social">
          <!-- Facebook -->
          <svg viewBox="0 0 24 24" fill="currentColor" width="18" height="18"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
        </a>
        <a href={site.social.youtube} aria-label="YouTube" target="_blank" rel="noopener noreferrer" class="footer-social">
          <!-- YouTube -->
          <svg viewBox="0 0 24 24" fill="currentColor" width="18" height="18"><path d="M23.495 6.205a3.007 3.007 0 00-2.088-2.088c-1.87-.501-9.396-.501-9.396-.501s-7.507-.01-9.396.501A3.007 3.007 0 00.527 6.205a31.247 31.247 0 00-.522 5.805 31.247 31.247 0 00.522 5.783 3.007 3.007 0 002.088 2.088c1.868.502 9.396.502 9.396.502s7.506 0 9.396-.502a3.007 3.007 0 002.088-2.088 31.247 31.247 0 00.5-5.783 31.247 31.247 0 00-.5-5.805zM9.609 15.601V8.408l6.264 3.602z"/></svg>
        </a>
        <a href={waLink} aria-label="WhatsApp" target="_blank" rel="noopener noreferrer" class="footer-social">
          <!-- WhatsApp -->
          <svg viewBox="0 0 24 24" fill="currentColor" width="18" height="18"><path d="M12.04 2C6.58 2 2.13 6.45 2.13 11.91c0 1.75.46 3.45 1.32 4.95L2 22l5.25-1.38c1.45.79 3.08 1.21 4.79 1.21h.01c5.46 0 9.91-4.45 9.91-9.91 0-2.65-1.03-5.14-2.9-7.01A9.82 9.82 0 0 0 12.04 2Zm5.8 14.18c-.25.69-1.45 1.32-1.99 1.4-.53.08-1.16.11-1.87-.12-.43-.14-.99-.32-1.7-.63-2.99-1.29-4.94-4.3-5.09-4.5-.15-.2-1.22-1.62-1.22-3.09 0-1.47.77-2.19 1.04-2.49.27-.3.59-.37.79-.37.2 0 .39.002.56.01.18.008.42-.07.66.5.25.59.84 2.04.91 2.19.07.15.12.32.02.52-.1.2-.15.32-.3.49-.15.17-.31.39-.45.52-.15.15-.3.31-.13.6.17.3.76 1.25 1.63 2.03 1.12 1 2.06 1.31 2.36 1.46.3.15.47.12.64-.07.17-.2.74-.86.94-1.16.2-.3.39-.25.66-.15.27.1 1.71.81 2 .96.3.15.5.22.57.35.07.12.07.72-.18 1.41Z"/></svg>
        </a>
      </div>
    </div>

    <div>
      <h3 class="text-sm font-semibold uppercase tracking-wider text-white">Explore</h3>
      <ul class="mt-4 space-y-2 text-sm">
        <li><a href="/about" class="hover:text-accent">About Shiyas</a></li>
        <li><a href="/programs" class="hover:text-accent">Programs</a></li>
        <li><a href="/pricing" class="hover:text-accent">Pricing</a></li>
        <li><a href="/results" class="hover:text-accent">Results</a></li>
        <li><a href="/blog" class="hover:text-accent">Blog</a></li>
        <li><a href="/tools" class="hover:text-accent">Free tools</a></li>
      </ul>
    </div>

    <div>
      <h3 class="text-sm font-semibold uppercase tracking-wider text-white">Get in touch</h3>
      <ul class="mt-4 space-y-2 text-sm">
        <li><a href={`tel:${site.phone.replace(/\s/g, "")}`} class="hover:text-accent">{site.phone}</a></li>
        <li><a href={`mailto:${site.email}`} class="hover:text-accent">{site.email}</a></li>
        <li><a href={waLink} class="hover:text-accent">WhatsApp</a></li>
        <li><a href="/book" class="hover:text-accent">Book a free trial</a></li>
      </ul>
    </div>
  </div>

  <div class="border-t border-white/10">
    <div class="container-tight flex flex-col items-center justify-between gap-2 py-5 text-xs text-white/50 sm:flex-row">
      <p>&copy; {year} {site.name}. All rights reserved.</p>
      <p>{site.trainer} · {site.city}</p>
    </div>
  </div>
</footer>

<style>
  @reference "../styles/global.css";
  .footer-social {
    @apply grid h-9 w-9 place-items-center rounded-full border border-white/20 text-white/70 transition hover:border-accent hover:text-accent;
  }
</style>
