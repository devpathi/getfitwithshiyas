---
// TDEE / daily calorie calculator (Mifflin-St Jeor) — client-side only.
---
<div class="calc rounded-2xl border border-black/8 bg-white p-7" data-calc="tdee">
  <h3 class="font-display text-xl font-bold">Calorie / TDEE Calculator</h3>
  <p class="mt-1 text-sm text-muted">Estimate your daily calorie needs.</p>

  <div class="mt-5 grid gap-4 sm:grid-cols-2">
    <label class="block text-sm font-medium">Gender
      <select name="gender" class="calc-input">
        <option value="male">Male</option>
        <option value="female">Female</option>
      </select>
    </label>
    <label class="block text-sm font-medium">Age (years)
      <input type="number" name="age" min="14" max="100" class="calc-input" placeholder="30" />
    </label>
    <label class="block text-sm font-medium">Weight (kg)
      <input type="number" name="weight" min="30" max="400" step="0.1" class="calc-input" placeholder="70" />
    </label>
    <label class="block text-sm font-medium">Height (cm)
      <input type="number" name="height" min="100" max="260" step="0.1" class="calc-input" placeholder="175" />
    </label>
    <label class="block text-sm font-medium sm:col-span-2">Activity level
      <select name="activity" class="calc-input">
        <option value="1.2">Sedentary (little / no exercise)</option>
        <option value="1.375">Light (1–3 days/week)</option>
        <option value="1.55" selected>Moderate (3–5 days/week)</option>
        <option value="1.725">Active (6–7 days/week)</option>
        <option value="1.9">Very active (hard training / physical job)</option>
      </select>
    </label>
  </div>
  <button type="button" class="btn-dark mt-5 w-full" data-action="calc">Calculate calories</button>

  <p class="calc-error mt-3 hidden text-sm text-red-600"></p>
  <div class="calc-result mt-5 hidden rounded-xl bg-cream p-5">
    <p class="text-center text-sm text-muted">Maintenance calories</p>
    <p class="text-center font-display text-4xl font-bold text-accent-dark" data-out="tdee"></p>
    <div class="mt-4 grid grid-cols-3 gap-3 text-center text-sm">
      <div><p class="text-xs text-muted">Lose fat</p><p class="font-bold" data-out="cut"></p></div>
      <div><p class="text-xs text-muted">Maintain</p><p class="font-bold" data-out="maintain"></p></div>
      <div><p class="text-xs text-muted">Build muscle</p><p class="font-bold" data-out="bulk"></p></div>
    </div>
    <p class="mt-3 text-center text-xs text-muted">kcal/day · an estimate to start from</p>
  </div>
</div>

<script>
  document.querySelectorAll<HTMLElement>('[data-calc="tdee"]').forEach((root) => {
    const val = (n: string) => (root.querySelector(`[name="${n}"]`) as HTMLInputElement)?.value;
    const num = (n: string) => parseFloat(val(n));
    const err = root.querySelector(".calc-error") as HTMLElement;
    const result = root.querySelector(".calc-result") as HTMLElement;
    const set = (k: string, v: string) =>
      ((root.querySelector(`[data-out="${k}"]`) as HTMLElement).textContent = v);

    root.querySelector('[data-action="calc"]')?.addEventListener("click", () => {
      const gender = val("gender");
      const age = num("age");
      const w = num("weight");
      const h = num("height");
      const act = num("activity");
      err.classList.add("hidden");
      if (!age || !w || !h || age <= 0 || w <= 0 || h <= 0) {
        err.textContent = "Please fill in age, weight and height with valid numbers.";
        err.classList.remove("hidden");
        result.classList.add("hidden");
        return;
      }
      // Mifflin-St Jeor
      const bmr = 10 * w + 6.25 * h - 5 * age + (gender === "male" ? 5 : -161);
      const tdee = bmr * act;
      const round = (n: number) => Math.round(n / 10) * 10;
      set("tdee", round(tdee).toLocaleString());
      set("cut", round(tdee - 500).toLocaleString());
      set("maintain", round(tdee).toLocaleString());
      set("bulk", round(tdee + 300).toLocaleString());
      result.classList.remove("hidden");
    });
  });
</script>
