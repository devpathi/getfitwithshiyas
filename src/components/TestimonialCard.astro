---
interface Props {
  name: string;
  result: string;
  photo?: string;
  body: string;
}
const { name, result, photo, body } = Astro.props;
const initials = name
  .replace(/\[\[.*?\]\]/g, "")
  .trim()
  .split(/\s+/)
  .map((w) => w[0])
  .filter(Boolean)
  .slice(0, 2)
  .join("")
  .toUpperCase() || "GF";
---

<figure class="flex h-full flex-col rounded-2xl bg-cream p-7">
  <div class="text-accent" aria-hidden="true">★★★★★</div>
  <blockquote class="mt-3 flex-1 text-sm leading-relaxed text-ink/80">“{body}”</blockquote>
  <figcaption class="mt-5 flex items-center gap-3">
    {
      photo ? (
        <img src={photo} alt={name} class="h-11 w-11 rounded-full object-cover" />
      ) : (
        <span class="grid h-11 w-11 place-items-center rounded-full bg-ink text-sm font-bold text-accent">{initials}</span>
      )
    }
    <div>
      <p class="text-sm font-semibold">{name}</p>
      <p class="text-xs text-accent-dark">{result}</p>
    </div>
  </figcaption>
</figure>
