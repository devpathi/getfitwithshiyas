---
interface Props {
  name: string;
  price: string;
  period?: string;
  mode?: string;
  features: string[];
  highlighted?: boolean;
  cta?: string;
}
const { name, price, period = "", mode = "", features, highlighted = false, cta = "Book a free trial" } = Astro.props;
---

<article
  class:list={[
    "relative flex h-full flex-col rounded-2xl border p-7",
    highlighted ? "border-accent bg-ink text-white shadow-xl" : "border-black/8 bg-white",
  ]}
>
  {highlighted && (
    <span class="absolute -top-3 left-7 rounded-full bg-accent px-3 py-1 text-xs font-bold text-ink">Most popular</span>
  )}
  <h3 class:list={["text-lg font-bold", highlighted ? "text-white" : "text-ink"]}>{name}</h3>
  {mode && <p class:list={["mt-1 text-xs", highlighted ? "text-white/60" : "text-muted"]}>{mode}</p>}
  <div class="mt-4 flex items-baseline gap-1">
    <span class="font-display text-3xl font-bold">{price}</span>
    {period && <span class:list={["text-sm", highlighted ? "text-white/60" : "text-muted"]}>{period}</span>}
  </div>
  <ul class="mt-6 flex-1 space-y-3 text-sm">
    {
      features.map((f) => (
        <li class="flex gap-2.5">
          <span class="text-accent">✓</span>
          <span class:list={highlighted ? "text-white/80" : "text-ink/75"}>{f}</span>
        </li>
      ))
    }
  </ul>
  <a href="/book" class:list={["mt-7", highlighted ? "btn-primary" : "btn-dark"]}>{cta}</a>
</article>
