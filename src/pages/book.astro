---
import Base from "../layouts/Base.astro";
import site from "../data/site.json";

const waLink = `https://wa.me/${site.whatsapp}?text=${encodeURIComponent(site.whatsappMessage)}`;
---

<Base title={`Book a Free Trial | ${site.name}`} description="Book your free, no-commitment trial session or consultation with Shiyas — in person or online.">
  <section class="bg-ink text-white">
    <div class="container-tight py-16 md:py-20">
      <p class="eyebrow text-accent">Book now</p>
      <h1 class="mt-3 font-display text-4xl font-bold md:text-5xl">Claim your free trial session</h1>
      <p class="mt-4 max-w-2xl text-lg text-white/70">No commitment. Reach out directly and Shiyas will get you started — in person in Bengaluru or online.</p>
    </div>
  </section>

  <section class="bg-white">
    <div class="container-tight py-16 md:py-20">
      <div class="mx-auto max-w-2xl">
        <h2 class="font-display text-2xl font-bold text-center">Get in touch to book</h2>
        <p class="mt-3 text-center text-ink/70">Pick the way that works best for you — Shiyas will confirm your session within 24 hours.</p>

        <div class="mt-10 grid gap-5 sm:grid-cols-3">
          <!-- WhatsApp -->
          <a
            href={waLink}
            target="_blank"
            rel="noopener noreferrer"
            class="flex flex-col items-center gap-3 rounded-2xl border border-black/8 bg-white p-7 text-center transition hover:border-accent hover:shadow-md"
          >
            <span class="grid h-14 w-14 place-items-center rounded-full bg-[#25D366]/10 text-[#25D366] text-3xl">
              <svg viewBox="0 0 24 24" fill="currentColor" width="32" height="32"><path d="M12.04 2C6.58 2 2.13 6.45 2.13 11.91c0 1.75.46 3.45 1.32 4.95L2 22l5.25-1.38c1.45.79 3.08 1.21 4.79 1.21h.01c5.46 0 9.91-4.45 9.91-9.91 0-2.65-1.03-5.14-2.9-7.01A9.82 9.82 0 0 0 12.04 2Zm5.8 14.18c-.25.69-1.45 1.32-1.99 1.4-.53.08-1.16.11-1.87-.12-.43-.14-.99-.32-1.7-.63-2.99-1.29-4.94-4.3-5.09-4.5-.15-.2-1.22-1.62-1.22-3.09 0-1.47.77-2.19 1.04-2.49.27-.3.59-.37.79-.37.2 0 .39.002.56.01.18.008.42-.07.66.5.25.59.84 2.04.91 2.19.07.15.12.32.02.52-.1.2-.15.32-.3.49-.15.17-.31.39-.45.52-.15.15-.3.31-.13.6.17.3.76 1.25 1.63 2.03 1.12 1 2.06 1.31 2.36 1.46.3.15.47.12.64-.07.17-.2.74-.86.94-1.16.2-.3.39-.25.66-.15.27.1 1.71.81 2 .96.3.15.5.22.57.35.07.12.07.72-.18 1.41Z"/></svg>
            </span>
            <p class="font-bold">WhatsApp</p>
            <p class="text-sm text-muted">Fastest reply — message Shiyas directly</p>
          </a>

          <!-- Phone -->
          <a
            href={`tel:${site.phone.replace(/\s/g, "")}`}
            class="flex flex-col items-center gap-3 rounded-2xl border border-black/8 bg-white p-7 text-center transition hover:border-accent hover:shadow-md"
          >
            <span class="grid h-14 w-14 place-items-center rounded-full bg-cream text-accent text-3xl">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="32" height="32"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 9.8a19.79 19.79 0 01-3.07-8.66A2 2 0 012 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L6.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
            </span>
            <p class="font-bold">Call</p>
            <p class="text-sm text-muted">{site.phone}</p>
          </a>

          <!-- Email -->
          <a
            href={`mailto:${site.email}?subject=Free Trial Booking`}
            class="flex flex-col items-center gap-3 rounded-2xl border border-black/8 bg-white p-7 text-center transition hover:border-accent hover:shadow-md"
          >
            <span class="grid h-14 w-14 place-items-center rounded-full bg-cream text-accent text-3xl">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="32" height="32"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
            </span>
            <p class="font-bold">Email</p>
            <p class="text-sm text-muted">{site.email}</p>
          </a>
        </div>
      </div>
    </div>
  </section>
</Base>
