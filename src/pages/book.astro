---
import Base from "../layouts/Base.astro";
import site from "../data/site.json";

const waLink = `https://wa.me/${site.whatsapp}?text=${encodeURIComponent(site.whatsappMessage)}`;
const isCalendlySet = !site.calendlyUrl.includes("your-calendly-handle");
---

<Base title="Book a Free Trial | Get Fit With Shiyas" description="Book your free, no-commitment trial session or consultation with Shiyas — in person or online.">
  <section class="bg-ink text-white">
    <div class="container-tight py-16 md:py-20">
      <p class="eyebrow text-accent">Book now</p>
      <h1 class="mt-3 font-display text-4xl font-bold md:text-5xl">Claim your free trial session</h1>
      <p class="mt-4 max-w-2xl text-lg text-white/70">No commitment. Pick a time below for a free consultation or trial — in person in Bengaluru or online.</p>
    </div>
  </section>

  <section class="bg-white">
    <div class="container-tight py-16 md:py-20">
      {
        isCalendlySet ? (
          <div
            class="calendly-inline-widget rounded-2xl border border-black/8"
            data-url={site.calendlyUrl}
            style="min-width:320px;height:700px;"
          />
        ) : (
          <div class="mx-auto max-w-2xl rounded-2xl border border-dashed border-accent/60 bg-cream p-8 text-center">
            <h2 class="font-display text-xl font-bold">[[SETUP: Calendly not connected yet]]</h2>
            <p class="mt-3 text-sm text-ink/70">
              Create a free Calendly account, make a “Free Consultation” event, copy its link,
              and paste it into <code class="rounded bg-white px-1.5 py-0.5">calendlyUrl</code> in
              <code class="rounded bg-white px-1.5 py-0.5">src/data/site.json</code>. The booking
              calendar will then appear here automatically.
            </p>
            <p class="mt-5 text-sm text-ink/70">In the meantime, clients can reach you directly:</p>
            <div class="mt-4 flex flex-wrap justify-center gap-3">
              <a href={waLink} target="_blank" rel="noopener noreferrer" class="btn-primary">WhatsApp Shiyas</a>
              <a href={`tel:${site.phone.replace(/\s/g, "")}`} class="btn-dark">Call {site.phone}</a>
            </div>
          </div>
        )
      }

      <p class="mt-8 text-center text-sm text-muted">
        Prefer to chat first? <a href={waLink} target="_blank" rel="noopener noreferrer" class="font-semibold text-accent-dark hover:underline">Message Shiyas on WhatsApp →</a>
      </p>
    </div>
  </section>

  {isCalendlySet && <script is:inline src="https://assets.calendly.com/assets/external/widget.js" async />}
</Base>
