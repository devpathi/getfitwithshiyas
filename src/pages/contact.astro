---
import Base from "../layouts/Base.astro";
import site from "../data/site.json";

const waLink = `https://wa.me/${site.whatsapp}?text=${encodeURIComponent(site.whatsappMessage)}`;
---

<Base title={`Contact | ${site.name}`} description={`Get in touch with ${site.trainer} — WhatsApp, phone, or email. Based in ${site.city}.`}>
  <section class="bg-ink text-white">
    <div class="container-tight py-16 md:py-20">
      <p class="eyebrow text-accent">Contact</p>
      <h1 class="mt-3 font-display text-4xl font-bold md:text-5xl">Let's talk</h1>
      <p class="mt-4 max-w-2xl text-lg text-white/70">Reach out directly — Shiyas will get back to you as soon as possible.</p>
    </div>
  </section>

  <section class="bg-white">
    <div class="container-tight py-16 md:py-20">
      <div class="grid gap-8 sm:grid-cols-3 max-w-3xl mx-auto">
        <!-- WhatsApp -->
        <a
          href={waLink}
          target="_blank"
          rel="noopener noreferrer"
          class="flex flex-col items-center gap-4 rounded-2xl border border-black/8 p-8 text-center transition hover:border-accent hover:shadow-md"
        >
          <span class="grid h-16 w-16 place-items-center rounded-full bg-[#25D366]/10">
            <svg viewBox="0 0 24 24" fill="#25D366" width="36" height="36"><path d="M12.04 2C6.58 2 2.13 6.45 2.13 11.91c0 1.75.46 3.45 1.32 4.95L2 22l5.25-1.38c1.45.79 3.08 1.21 4.79 1.21h.01c5.46 0 9.91-4.45 9.91-9.91 0-2.65-1.03-5.14-2.9-7.01A9.82 9.82 0 0 0 12.04 2Zm5.8 14.18c-.25.69-1.45 1.32-1.99 1.4-.53.08-1.16.11-1.87-.12-.43-.14-.99-.32-1.7-.63-2.99-1.29-4.94-4.3-5.09-4.5-.15-.2-1.22-1.62-1.22-3.09 0-1.47.77-2.19 1.04-2.49.27-.3.59-.37.79-.37.2 0 .39.002.56.01.18.008.42-.07.66.5.25.59.84 2.04.91 2.19.07.15.12.32.02.52-.1.2-.15.32-.3.49-.15.17-.31.39-.45.52-.15.15-.3.31-.13.6.17.3.76 1.25 1.63 2.03 1.12 1 2.06 1.31 2.36 1.46.3.15.47.12.64-.07.17-.2.74-.86.94-1.16.2-.3.39-.25.66-.15.27.1 1.71.81 2 .96.3.15.5.22.57.35.07.12.07.72-.18 1.41Z"/></svg>
          </span>
          <div>
            <p class="font-bold text-lg">WhatsApp</p>
            <p class="text-sm text-muted mt-1">Chat with Shiyas directly</p>
          </div>
        </a>

        <!-- Phone -->
        <a
          href={`tel:${site.phone.replace(/\s/g, "")}`}
          class="flex flex-col items-center gap-4 rounded-2xl border border-black/8 p-8 text-center transition hover:border-accent hover:shadow-md"
        >
          <span class="grid h-16 w-16 place-items-center rounded-full bg-cream">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="36" height="36" class="text-accent"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 9.8a19.79 19.79 0 01-3.07-8.66A2 2 0 012 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L6.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
          </span>
          <div>
            <p class="font-bold text-lg">Call</p>
            <p class="text-sm text-muted mt-1">{site.phone}</p>
          </div>
        </a>

        <!-- Email -->
        <a
          href={`mailto:${site.email}`}
          class="flex flex-col items-center gap-4 rounded-2xl border border-black/8 p-8 text-center transition hover:border-accent hover:shadow-md"
        >
          <span class="grid h-16 w-16 place-items-center rounded-full bg-cream">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="36" height="36" class="text-accent"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
          </span>
          <div>
            <p class="font-bold text-lg">Email</p>
            <p class="text-sm text-muted mt-1">{site.email}</p>
          </div>
        </a>
      </div>

      <!-- Map -->
      <div class="mt-12 max-w-3xl mx-auto overflow-hidden rounded-2xl border border-black/8">
        <iframe
          title="Location map"
          src="https://www.google.com/maps?q=Indiranagar%2C%20Bengaluru&output=embed"
          class="h-64 w-full"
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"></iframe>
      </div>
    </div>
  </section>
</Base>
