---
import Base from "../layouts/Base.astro";
import site from "../data/site.json";

const waLink = `https://wa.me/${site.whatsapp}?text=${encodeURIComponent(site.whatsappMessage)}`;
---

<Base title="Contact | Get Fit With Shiyas" description={`Get in touch with ${site.trainer} — WhatsApp, phone, email, or send a message. Based in ${site.city}.`}>
  <section class="bg-ink text-white">
    <div class="container-tight py-16 md:py-20">
      <p class="eyebrow text-accent">Contact</p>
      <h1 class="mt-3 font-display text-4xl font-bold md:text-5xl">Let's talk</h1>
      <p class="mt-4 max-w-2xl text-lg text-white/70">Have a question or ready to start? Reach out and Shiyas will get back to you.</p>
    </div>
  </section>

  <section class="bg-white">
    <div class="container-tight grid gap-12 py-16 md:grid-cols-2 md:py-20">
      <!-- Contact details -->
      <div>
        <h2 class="font-display text-2xl font-bold">Reach out directly</h2>
        <ul class="mt-6 space-y-4">
          <li class="flex items-center gap-4">
            <span class="grid h-11 w-11 place-items-center rounded-full bg-[#25D366]/10 text-[#25D366]">●</span>
            <div><p class="text-xs text-muted">WhatsApp</p><a href={waLink} target="_blank" rel="noopener noreferrer" class="font-semibold hover:text-accent-dark">Chat with Shiyas</a></div>
          </li>
          <li class="flex items-center gap-4">
            <span class="grid h-11 w-11 place-items-center rounded-full bg-cream text-accent-dark">☎</span>
            <div><p class="text-xs text-muted">Phone</p><a href={`tel:${site.phone.replace(/\s/g, "")}`} class="font-semibold hover:text-accent-dark">{site.phone}</a></div>
          </li>
          <li class="flex items-center gap-4">
            <span class="grid h-11 w-11 place-items-center rounded-full bg-cream text-accent-dark">✉</span>
            <div><p class="text-xs text-muted">Email</p><a href={`mailto:${site.email}`} class="font-semibold hover:text-accent-dark">{site.email}</a></div>
          </li>
          <li class="flex items-center gap-4">
            <span class="grid h-11 w-11 place-items-center rounded-full bg-cream text-accent-dark">📍</span>
            <div><p class="text-xs text-muted">Location</p><p class="font-semibold">{site.city}</p></div>
          </li>
        </ul>

        <div class="mt-8 overflow-hidden rounded-2xl border border-black/8">
          <!-- [[REPLACE: paste a Google Maps embed iframe for the studio location, or leave as-is]] -->
          <iframe
            title="Location map"
            src="https://www.google.com/maps?q=Indiranagar%2C%20Bengaluru&output=embed"
            class="h-64 w-full"
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"></iframe>
        </div>
      </div>

      <!-- Netlify form -->
      <div>
        <h2 class="font-display text-2xl font-bold">Send a message</h2>
        <p class="mt-2 text-sm text-muted">Fill this in and Shiyas will reply, usually within a day.</p>

        <form
          name="contact"
          method="POST"
          data-netlify="true"
          netlify-honeypot="bot-field"
          action="/thank-you"
          class="mt-6 space-y-4"
        >
          <input type="hidden" name="form-name" value="contact" />
          <p class="hidden"><label>Don't fill this out: <input name="bot-field" /></label></p>

          <div>
            <label for="name" class="block text-sm font-medium">Name</label>
            <input id="name" name="name" required class="form-input" placeholder="Your name" />
          </div>
          <div class="grid gap-4 sm:grid-cols-2">
            <div>
              <label for="email" class="block text-sm font-medium">Email</label>
              <input id="email" name="email" type="email" required class="form-input" placeholder="you@example.com" />
            </div>
            <div>
              <label for="phone" class="block text-sm font-medium">Phone</label>
              <input id="phone" name="phone" class="form-input" placeholder="+91 ..." />
            </div>
          </div>
          <div>
            <label for="goal" class="block text-sm font-medium">Your goal</label>
            <select id="goal" name="goal" class="form-input">
              <option>Fat loss / weight loss</option>
              <option>Build muscle</option>
              <option>General fitness & strength</option>
              <option>Online coaching</option>
              <option>Something else</option>
            </select>
          </div>
          <div>
            <label for="message" class="block text-sm font-medium">Message</label>
            <textarea id="message" name="message" rows="4" class="form-input" placeholder="Tell Shiyas a little about your goals..."></textarea>
          </div>
          <button type="submit" class="btn-primary w-full">Send message</button>
        </form>
      </div>
    </div>
  </section>
</Base>

<style>
  @reference "../styles/global.css";
  .form-input {
    @apply mt-1.5 w-full rounded-xl border border-black/12 bg-white px-4 py-2.5 text-sm
           outline-none transition focus:border-accent focus:ring-2 focus:ring-accent/30;
  }
</style>
