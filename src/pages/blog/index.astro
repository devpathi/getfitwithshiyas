---
import { getCollection } from "astro:content";
import Base from "../../layouts/Base.astro";

const posts = (await getCollection("blog", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);
const fmt = (d: Date) => d.toLocaleDateString("en-IN", { day: "numeric", month: "short", year: "numeric" });
---

<Base title="Blog | Get Fit With Shiyas" description="Fitness, nutrition, and training tips from coach Shiyas.">
  <section class="bg-ink text-white">
    <div class="container-tight py-16 md:py-20">
      <p class="eyebrow text-accent">Blog</p>
      <h1 class="mt-3 font-display text-4xl font-bold md:text-5xl">Training & nutrition tips</h1>
      <p class="mt-4 max-w-2xl text-lg text-white/70">Practical advice from {posts.length > 0 ? "the coaching floor" : "Shiyas"} — no fads, no nonsense.</p>
    </div>
  </section>

  <section class="bg-white">
    <div class="container-tight py-16 md:py-20">
      {
        posts.length === 0 ? (
          <p class="text-muted">No posts yet — check back soon.</p>
        ) : (
          <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
            {posts.map((post) => (
              <article class="group flex flex-col">
                <a href={`/blog/${post.slug}`} class="block aspect-[16/10] overflow-hidden rounded-2xl bg-cream">
                  {post.data.cover ? (
                    <img src={post.data.cover} alt={post.data.title} class="h-full w-full object-cover transition group-hover:scale-105" />
                  ) : (
                    <div class="flex h-full items-center justify-center text-muted text-sm">Get Fit With Shiyas</div>
                  )}
                </a>
                <p class="mt-4 text-xs text-muted">{fmt(post.data.date)}</p>
                <h2 class="mt-1 text-lg font-bold leading-snug">
                  <a href={`/blog/${post.slug}`} class="hover:text-accent-dark">{post.data.title}</a>
                </h2>
                <p class="mt-2 flex-1 text-sm text-ink/70">{post.data.description}</p>
                <a href={`/blog/${post.slug}`} class="mt-3 text-sm font-semibold text-accent-dark hover:underline">Read more →</a>
              </article>
            ))}
          </div>
        )
      }
    </div>
  </section>
</Base>
