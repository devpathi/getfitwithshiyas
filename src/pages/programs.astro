---
import { getCollection } from "astro:content";
import Base from "../layouts/Base.astro";
import ProgramCard from "../components/ProgramCard.astro";
import CTASection from "../components/CTASection.astro";

const programs = (await getCollection("programs")).sort((a, b) => a.data.order - b.data.order);
---

<Base title="Programs & Services | Get Fit With Shiyas" description="Personal training, online coaching, weight-loss coaching and bodybuilding — in-person in Bengaluru and online anywhere.">
  <section class="bg-ink text-white">
    <div class="container-tight py-16 md:py-20">
      <p class="eyebrow text-accent">Programs & services</p>
      <h1 class="mt-3 font-display text-4xl font-bold md:text-5xl">Find the program that fits you</h1>
      <p class="mt-4 max-w-2xl text-lg text-white/70">In-person in Bengaluru or online from anywhere — every program is fully personalised.</p>
    </div>
  </section>

  <section class="bg-white">
    <div class="container-tight py-16 md:py-20">
      <div class="grid gap-6 sm:grid-cols-2">
        {programs.map((p) => <ProgramCard title={p.data.title} summary={p.data.summary} mode={p.data.mode} bestFor={p.data.bestFor} />)}
      </div>
    </div>
  </section>

  <CTASection heading="Not sure which program is right?" text="Book a free consultation and Shiyas will recommend the best fit for your goals." />
</Base>
