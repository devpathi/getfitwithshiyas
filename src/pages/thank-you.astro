---
import Base from "../layouts/Base.astro";
import site from "../data/site.json";
const waLink = `https://wa.me/${site.whatsapp}?text=${encodeURIComponent(site.whatsappMessage)}`;
---

<Base title={`Thank you | ${site.name}`}>
  <section class="bg-ink text-white">
    <div class="container-tight flex min-h-[60vh] flex-col items-center justify-center py-20 text-center">
      <div class="grid h-16 w-16 place-items-center rounded-full bg-accent text-2xl text-ink">✓</div>
      <h1 class="mt-6 font-display text-3xl font-bold md:text-4xl">Message received!</h1>
      <p class="mt-4 max-w-md text-white/70">Thanks for reaching out. Shiyas will get back to you soon. Want a faster reply? Message on WhatsApp.</p>
      <div class="mt-8 flex flex-wrap justify-center gap-4">
        <a href={waLink} target="_blank" rel="noopener noreferrer" class="btn-primary">WhatsApp Shiyas</a>
        <a href="/" class="btn-outline">Back to home</a>
      </div>
    </div>
  </section>
</Base>
